# Ignore IDE-specific files and directories
.vscode/
.idea/
*.iml
*.ipr
*.iws
.atom/

# Ignore OS-generated files and temporary files
.DS_Store
*.swp
.history
.buildlog/

# Ignore log files
*.log

# Ignore compiled code and build artifacts
*.class
*.pyc
/build/
/android/app/debug/
/android/app/profile/
/android/app/release/

# Ignore Flutter/Dart specific files and directories
.dart_tool/
.pub-cache/
.pub/
**/doc/api/
**/ios/Flutter/.last_build_id
.flutter-plugins
.flutter-plugins-dependencies
app.*.symbols
app.*.map.json

# Ignore version control and migration artifacts
.svn/
migrate_working_dir/

# Ignore Flutter Version Management (FVM) cache
.fvm/

# Ignore platform-specific build output directories
ios/
android/
web/
linux/
macos/
windows/

# Other ignored files
.todo